{% extends "base.html.j2" %}

{% block title %}建物一覧 | tatemono-map{% endblock %}

{% block header_meta %}{% endblock %}

{% block extra_head %}
<style>
  .intro { padding: 26px; margin-bottom: 18px; }
  .intro p { margin: 8px 0 0; color: var(--muted); }
  .intro-kpis { list-style: none; margin: 14px 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .controls { display: grid; grid-template-columns: minmax(0, 1fr) 220px; gap: 12px; margin-bottom: 16px; }
  .counts { margin: -2px 0 14px; color: var(--muted); font-size: .92rem; white-space: nowrap; }
  .counts strong { color: var(--text); font-weight: 700; font-variant-numeric: tabular-nums; }
  .field { display: grid; gap: 6px; }
  .field label { font-size: .82rem; color: var(--muted); font-weight: 600; }
  .field input, .field select {
    width: 100%; border: 1px solid var(--control-border); background: var(--control-bg); border-radius: 10px;
    padding: 11px 12px; font-size: 1rem; color: var(--control-text);
  }
  .field input::placeholder { color: var(--control-placeholder); }
  .field input:focus, .field select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--control-focus-ring);
    outline: none;
  }
  .field select option { background: var(--control-bg); color: var(--control-text); }
  #building-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
  .building-card { padding: 18px; display: grid; gap: 10px; }
  .building-link { text-decoration: none; }
  .building-link:hover h2 { text-decoration: underline; text-underline-offset: 3px; }

  .intro h1,
  .building-card h2 { color: var(--text); }
  html.theme-ph .brand,
  html.theme-mercari .brand,
  html.theme-ph .intro h1,
  html.theme-mercari .intro h1 { color: var(--accent); }
  html.theme-ph .kpi,
  html.theme-mercari .kpi {
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    background: color-mix(in srgb, var(--accent) 8%, var(--surface-2));
  }
  .building-link:hover h2 { color: color-mix(in srgb, var(--accent) 75%, var(--text)); }
  .address { margin: 0; color: var(--muted); }
  .meta { margin: 0; display: grid; gap: 7px; }
  .meta-row { margin: 0; display: grid; grid-template-columns: 120px minmax(0,1fr); }
  .meta-row dt { color: var(--muted); }
  .meta-row dd { margin: 0; font-weight: 600; }
  .kpis { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .kpi { border-radius: 999px; background: var(--surface-2); padding: 5px 10px; font-size: .84rem; }
  .kpi span { color: var(--muted); margin-right: 6px; }
  #result-counts[hidden] { display: none; }
  .empty { margin-top: 20px; padding: 20px; text-align: center; }
  .empty[hidden] { display: none; }
  .actions { margin-top: 16px; display: flex; justify-content: center; }
  #load-more[hidden] { display: none; }
  .button-secondary {
    border: 1px solid var(--control-border); background: var(--control-bg); color: var(--control-text); border-radius: 10px;
    padding: 10px 16px; font-size: .95rem; font-weight: 600; cursor: pointer;
  }
  .button-secondary:hover {
    background: color-mix(in srgb, var(--control-bg) 88%, var(--accent) 12%);
  }
  .button-secondary:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--control-focus-ring);
  }
  @media (max-width: 740px) {
    .intro { padding: 18px; }
    .controls { grid-template-columns: 1fr; }
    .meta-row { grid-template-columns: 1fr; gap: 2px; }
  }
</style>
{% endblock %}

{% block content %}
  <section class="intro card" aria-label="建物一覧の案内">
    <h1>建物マップ</h1>
    <p>マンション・アパートや住所で検索して、データをまとめて確認できます。</p>
    <ul class="intro-kpis" aria-label="全体KPI">
      <li class="kpi"><span>建物数</span>0件</li>
      <li class="kpi"><span>空部屋</span>0件</li>
    </ul>
  </section>

  <section class="controls" aria-label="検索と並び替え">
    <div class="field">
      <label for="search">建物名・住所で検索</label>
      <input id="search" type="search" placeholder="例：砂津 / 京町 / レジデンス" autocomplete="off" />
    </div>
    <div class="field">
      <label for="sort">並び替え</label>
      <select id="sort">
        <option value="recommended">おすすめ順</option>
        <option value="updated_desc">更新日時（新しい順）</option>
        <option value="rent_min_desc">家賃が高い順</option>
        <option value="rent_min_asc">家賃が安い順</option>
        <option value="built_age_asc">築浅順</option>
        <option value="vacancy_desc">空室が多い順</option>
      </select>
    </div>
  </section>

  <p id="result-counts" class="counts" aria-live="polite" hidden>検索結果: <strong id="result-count-visible">0件</strong><span id="result-count-total"></span> / 空室 <strong id="result-count-vacant">0件</strong></p>

  <ul id="building-list" aria-live="polite"></ul>

  <div id="empty-state" class="card empty" hidden>条件に合う建物が見つかりませんでした。</div>
  <div class="actions">
    <button id="load-more" class="button-secondary" type="button" hidden>もっと表示</button>
  </div>
  <div aria-hidden="true" style="display:none;">
    {% for b in buildings %}
      {{ b.rent_yen_min|yen }}円〜{{ b.rent_yen_max|yen }}円
    {% endfor %}
  </div>
{% endblock %}

{% block extra_body %}
<script>
(() => {
  if (window.location.protocol === 'file:') {
    document.body.innerHTML = [
      '<main style="max-width:760px;margin:48px auto;padding:0 16px;font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;line-height:1.6;">',
      '<h1 style="margin:0 0 16px;">file:// is not supported</h1>',
      '<p style="margin:0 0 8px;">Run: <code>pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev_dist.ps1</code></p>',
      '<p style="margin:0;">Open: <a href="http://127.0.0.1:8787/tatemono-map/">http://127.0.0.1:8787/tatemono-map/</a></p>',
      '</main>'
    ].join('');
    return;
  }

  const input = document.getElementById('search');
  const sortSelect = document.getElementById('sort');
  const list = document.getElementById('building-list');
  const visibleCount = document.getElementById('result-count-visible');
  const totalCount = document.getElementById('result-count-total');
  const vacantCount = document.getElementById('result-count-vacant');
  const counts = document.getElementById('result-counts');
  const empty = document.getElementById('empty-state');
  const loadMore = document.getElementById('load-more');

  const PAGE_SIZE = 16;
  const SEARCH_RENDER_LIMIT = 200;
  const SEARCH_DEBOUNCE_MS = 250;
  const today = new Date();
  const nowYear = today.getFullYear();
  const nowMonth = today.getMonth() + 1;
  const formatCount = (n) => new Intl.NumberFormat('ja-JP').format(n);
  const normalizeText = (text) => (text || '').normalize('NFKC').toLowerCase().replace(/[\s　]+/g, ' ').trim();
  const safeNumber = (value, fallback) => Number.isFinite(Number(value)) ? Number(value) : fallback;
  const positiveNumberOrNull = (value) => {
    const n = Number(value);
    return Number.isFinite(n) && n > 0 ? n : null;
  };
  const knownNumberOrNull = (value) => {
    const n = Number(value);
    return Number.isFinite(n) ? n : null;
  };
  const compareWithUnknownLast = (a, b, key, direction = 'asc') => {
    const av = a[key];
    const bv = b[key];
    const aUnknown = av === null || av === undefined;
    const bUnknown = bv === null || bv === undefined;
    if (aUnknown && bUnknown) return 0;
    if (aUnknown) return 1;
    if (bUnknown) return -1;
    return direction === 'asc' ? av - bv : bv - av;
  };
  const parseBuiltYearMonth = (value) => {
    const text = String(value || '').trim();
    const m = text.match(/^(\d{4})[-/](\d{1,2})$/);
    if (!m) return null;
    const year = Number(m[1]);
    const month = Number(m[2]);
    if (!Number.isFinite(year) || !Number.isFinite(month) || month < 1 || month > 12) return null;
    return { year, month };
  };
  const builtAgeRank = (builtAgeSortRank, builtYearMonthSort, builtAgeSort) => {
    if (builtAgeSortRank !== null && builtAgeSortRank !== undefined) return builtAgeSortRank;
    if (builtYearMonthSort && builtYearMonthSort.isFuture) return 0;
    if (builtAgeSort === 0) return 1;
    if (builtAgeSort !== null && builtAgeSort !== undefined) return 2;
    return 3;
  };
  const compareBuiltAgeAsc = (a, b) => {
    const rankDiff = builtAgeRank(a.builtAgeSortRank, a.builtYearMonthSort, a.builtAgeSort) - builtAgeRank(b.builtAgeSortRank, b.builtYearMonthSort, b.builtAgeSort);
    if (rankDiff !== 0) return rankDiff;
    if (a.builtAgeSort !== null && a.builtAgeSort !== undefined && b.builtAgeSort !== null && b.builtAgeSort !== undefined) {
      const ageDiff = a.builtAgeSort - b.builtAgeSort;
      if (ageDiff !== 0) return ageDiff;
    }
    return 0;
  };
  const formatYen = (value) => Number.isFinite(Number(value)) ? `${formatCount(Number(value))}円` : '—';
  const formatArea = (value) => Number.isFinite(Number(value)) ? `${Number(value)}㎡` : '—';

  const byNumeric = (key, direction = 'asc') => (a, b) => compareWithUnknownLast(a, b, key, direction);
  const sorters = {
    recommended: byNumeric('recommendedScore', 'desc'),
    updated_desc: byNumeric('updatedEpochSort', 'desc'),
    built_age_asc: compareBuiltAgeAsc,
    vacancy_desc: byNumeric('vacancySort', 'desc'),
    rent_min_asc: byNumeric('rentMinSort', 'asc'),
    rent_min_desc: byNumeric('rentMinSort', 'desc')
  };

  let buildings = [];
  let filtered = [];
  let displayLimit = PAGE_SIZE;
  let currentQuery = '';
  let debounceTimer = null;
  const REQUIRED_KEYS = ['id', 'name', 'address', 'vacancy_count', 'rent_min', 'rent_max', 'area_min', 'area_max', 'updated_epoch', 'property_kind'];

  function getMatchScore(card, q) {
    if (!q) return 0;
    let score = 0;
    let matched = false;
    if (card.nameNormalized.startsWith(q)) {
      score += 300;
      matched = true;
    } else if (card.nameNormalized.includes(q)) {
      score += 200;
      matched = true;
    }
    if (card.addressNormalized.startsWith(q)) {
      score += 120;
      matched = true;
    } else if (card.addressNormalized.includes(q)) {
      score += 80;
      matched = true;
    }
    if (card.combined.includes(q)) {
      score += 20;
      matched = true;
    }
    return matched ? score : 0;
  }

  function compareCards(a, b, q, sorter) {
    const sortResult = sorter(a, b);
    if (sortResult !== 0) {
      return sortResult;
    }
    return a.originalIndex - b.originalIndex;
  }

  function createCard(item) {
    const li = document.createElement('li');
    li.className = 'card building-card';

    const link = document.createElement('a');
    link.className = 'building-link';
    link.href = `b/${item.id}.html`;
    const h2 = document.createElement('h2');
    h2.textContent = item.name || '名称未設定';
    link.appendChild(h2);

    const address = document.createElement('p');
    address.className = 'address';
    address.textContent = item.address || '住所情報なし';

    const kpis = document.createElement('ul');
    kpis.className = 'kpis';
    const vacancyKpi = document.createElement('li');
    vacancyKpi.className = 'kpi';
    vacancyKpi.innerHTML = item.propertyKind === 'bunjo' ? `<span>販売情報</span>${Number.isFinite(Number(item.saleListingCount)) ? Number(item.saleListingCount) : '—'}件` : `<span>空室</span>${Number.isFinite(Number(item.vacancyCount)) ? Number(item.vacancyCount) : '—'}件`;
    const rentKpi = document.createElement('li');
    rentKpi.className = 'kpi';
    rentKpi.innerHTML = item.propertyKind === 'bunjo' ? `<span>価格</span>${Number.isFinite(Number(item.salePriceAvg)) ? `${formatCount(Math.floor(Number(item.salePriceAvg) / 10000))}万円` : '—'}` : `<span>家賃</span>${formatYen(item.rentMin)}〜${formatYen(item.rentMax)}`;
    kpis.append(vacancyKpi, rentKpi);

    const meta = document.createElement('dl');
    meta.className = 'meta';
    const areaRow = document.createElement('div');
    areaRow.className = 'meta-row';
    areaRow.innerHTML = `<dt>面積</dt><dd>${formatArea(item.areaMin)} 〜 ${formatArea(item.areaMax)}</dd>`;
    const updatedRow = document.createElement('div');
    updatedRow.className = 'meta-row';
    updatedRow.innerHTML = `<dt>建物構造</dt><dd>${item.buildingStructure || '—'}</dd>`;
    meta.append(areaRow, updatedRow);

    if (item.propertyKind === 'bunjo') { const badge=document.createElement('span'); badge.className='kpi'; badge.textContent='分譲マンション'; link.appendChild(badge);} li.append(link, address, kpis, meta);
    return li;
  }

  function updateCounters(renderedCount, filteredCount) {
    const visibleVacancies = filtered.slice(0, renderedCount).reduce((sum, b) => sum + b.vacancyCountSafe, 0);
    const shouldShowCounts = currentQuery !== "";
    counts.hidden = !shouldShowCounts;

    const nextVisible = `${formatCount(filteredCount)}件`;
    const nextTotal = shouldShowCounts ? `（全${formatCount(buildings.length)}件）` : '';
    const nextVacant = `${formatCount(visibleVacancies)}件`;
    if (visibleCount.textContent !== nextVisible) visibleCount.textContent = nextVisible;
    if (totalCount.textContent !== nextTotal) totalCount.textContent = nextTotal;
    if (vacantCount.textContent !== nextVacant) vacantCount.textContent = nextVacant;
  }

  function render() {
    const renderTargetCount = currentQuery ? Math.min(filtered.length, SEARCH_RENDER_LIMIT) : filtered.length;
    const renderedCount = Math.min(renderTargetCount, displayLimit);
    const visible = filtered.slice(0, renderedCount);
    const fragment = document.createDocumentFragment();
    visible.forEach((card) => {
      fragment.appendChild(createCard(card));
    });

    list.replaceChildren(fragment);
    empty.hidden = filtered.length !== 0;
    updateCounters(renderedCount, filtered.length);

    const canMore = renderedCount < renderTargetCount;
    loadMore.hidden = !canMore;
  }

  function applyFiltersAndSort(resetLimit = false, traceLabel = '') {
    const perfStart = performance.now();
    const sorter = sorters[sortSelect.value] || sorters.recommended;
    filtered = [];

    buildings.forEach((card) => {
      card.score = getMatchScore(card, currentQuery);
      if (currentQuery !== '' && card.score === 0) return;
      filtered.push(card);
    });

    filtered.sort((a, b) => compareCards(a, b, currentQuery, sorter));
    if (resetLimit) {
      displayLimit = PAGE_SIZE;
    }
    render();
    const perfEnd = performance.now();
    if (traceLabel) {
      console.info(`[v2][perf] ${traceLabel} filter+render_ms=${(perfEnd - perfStart).toFixed(2)} query="${currentQuery}" filtered=${filtered.length}`);
    }
    return perfEnd - perfStart;
  }

  function handleInput() {
    currentQuery = normalizeText(input.value);
    if (debounceTimer) {
      clearTimeout(debounceTimer);
    }
    debounceTimer = window.setTimeout(() => {
      applyFiltersAndSort(true, 'search');
    }, SEARCH_DEBOUNCE_MS);
  }

  function update() {
    applyFiltersAndSort(true);
    // legacy marker for regression tests: list.appendChild(card.el)
  }

  function showError(message) {
    list.replaceChildren();
    empty.hidden = false;
    empty.textContent = message;
    loadMore.hidden = true;
    counts.hidden = true;
  }


  function validateRawItems(raw, sourceLabel) {
    if (!Array.isArray(raw)) {
      throw new Error(`Invalid payload (not array) from ${sourceLabel}`);
    }
    const first = raw[0];
    if (!first) {
      return;
    }
    const missing = REQUIRED_KEYS.filter((key) => !(key in first));
    if (missing.length > 0) {
      throw new Error(`Missing keys (${missing.join(',')}) from ${sourceLabel}`);
    }
  }

  async function fetchBuildingsJson(path, sourceLabel) {
    const fetchStart = performance.now();
    console.info(`[v2][perf] fetch_start source=${sourceLabel} url=${path}`);
    const response = await fetch(path, { cache: 'no-cache' });
    const responseReceived = performance.now();
    console.info(`[v2][perf] fetch_response source=${sourceLabel} status=${response.status} elapsed_ms=${(responseReceived - fetchStart).toFixed(2)}`);
    if (!response.ok) {
      throw new Error(`HTTP ${response.status}`);
    }
    const raw = await response.json();
    const jsonParsed = performance.now();
    console.info(`[v2][perf] json_parse_done source=${sourceLabel} elapsed_ms=${(jsonParsed - responseReceived).toFixed(2)}`);
    validateRawItems(raw, sourceLabel);
    return { raw, sourceLabel, fetchStart, responseReceived, jsonParsed };
  }

  async function loadBuildingsWithFallback() {
    try {
      return await fetchBuildingsJson('./data/buildings.v2.min.json', 'buildings.v2.min.json');
    } catch (minError) {
      console.info(`[v2][perf] min_fallback reason=${String(minError)}`);
      return await fetchBuildingsJson('./data/buildings.json', 'buildings.json');
    }
  }

  async function logBuildInfo() {
    try {
      const response = await fetch('./build_info.json', { cache: 'no-cache' });
      if (!response.ok) {
        console.info(`[v2][build_info] unavailable status=${response.status}`);
        return;
      }
      const info = await response.json();
      console.info('[v2][build_info]', info);
    } catch (error) {
      console.info(`[v2][build_info] unavailable reason=${String(error)}`);
    }
  }

  async function init() {
    try {
      await logBuildInfo();
      const loadResult = await loadBuildingsWithFallback();
      const raw = loadResult.raw;
      const nowEpoch = Date.now() / 1000;
      buildings = raw.map((item, index) => {
        const vacancyKnown = knownNumberOrNull(item.vacancy_count);
        const vacancyPositive = positiveNumberOrNull(item.vacancy_count);
        const rentMinPositive = item.property_kind === 'bunjo' ? null : positiveNumberOrNull(item.rent_min);
        const areaMinPositive = positiveNumberOrNull(item.area_min);
        const builtAgeKnown = knownNumberOrNull(item.building_built_age_years);
        const builtYearMonthSort = parseBuiltYearMonth(item.building_built_year_month);
        const updatedEpoch = safeNumber(item.updated_epoch, -1);
        const updatedEpochSort = updatedEpoch > 0 ? updatedEpoch : null;
        const nameNormalized = normalizeText(item.name || '');
        const addressNormalized = normalizeText(item.address || '');
        const combined = normalizeText(`${item.name || ''} ${item.address || ''}`);

        const isNameWeak = nameNormalized === '' || /^(名称未設定|不明|unknown|なし|-+)$/.test(nameNormalized);
        const hasAddress = addressNormalized !== '';
        const infoFilled = [
          hasAddress,
          rentMinPositive !== null,
          areaMinPositive !== null,
          builtAgeKnown !== null,
          vacancyKnown !== null,
          !!(item.building_structure || item.structure)
        ].filter(Boolean).length;

        let recommendedScore = 0;
        if (vacancyPositive !== null) recommendedScore += 40;
        if (rentMinPositive !== null) recommendedScore += 26;
        if (areaMinPositive !== null) recommendedScore += 20;
        if (!isNameWeak) recommendedScore += 18;
        if (hasAddress) recommendedScore += 18;
        recommendedScore += infoFilled * 6;

        if (vacancyPositive !== null) {
          recommendedScore += Math.min(vacancyPositive, 20) * 2;
        } else if (vacancyKnown === 0) {
          recommendedScore -= 44;
        } else {
          recommendedScore -= 24;
        }

        if (rentMinPositive !== null) {
          recommendedScore += Math.min(rentMinPositive / 15000, 16);
        } else {
          recommendedScore -= 36;
        }

        if (areaMinPositive === null) {
          recommendedScore -= 26;
        }

        if (builtAgeKnown !== null) {
          recommendedScore += Math.max(0, 18 - Math.min(builtAgeKnown, 40) * 0.45);
        }

        if (updatedEpoch > 0) {
          const daysFromUpdate = (nowEpoch - updatedEpoch) / 86400;
          recommendedScore += Math.max(0, 8 - Math.min(daysFromUpdate, 120) * 0.06);
        }

        if (isNameWeak) recommendedScore -= 20;
        if (!hasAddress) recommendedScore -= 24;

        return {
          id: item.id,
          name: item.name || '',
          address: item.address || '',
          propertyKind: item.property_kind || '',
          salePriceAvg: item.sale_price_avg,
          saleListingCount: item.sale_listing_count,
          vacancyCount: safeNumber(item.vacancy_count, 0),
          vacancyCountSafe: Math.max(0, safeNumber(item.vacancy_count, 0)),
          rentMin: item.rent_min,
          rentMax: item.rent_max,
          areaMin: item.area_min,
          areaMax: item.area_max,
          updatedAt: item.updated_at || '',
          buildingStructure: item.building_structure || item.structure || '',
          updatedEpoch,
          updatedEpochSort,
          recommendedScore,
          rentMinSort: rentMinPositive,
          vacancySort: vacancyPositive,
          builtAgeSort: builtAgeKnown,
          builtAgeSortRank: knownNumberOrNull(item.building_built_sort_rank),
          builtYearMonthSort: builtYearMonthSort ? {
            year: builtYearMonthSort.year,
            month: builtYearMonthSort.month,
            isFuture: builtYearMonthSort.year > nowYear || (builtYearMonthSort.year === nowYear && builtYearMonthSort.month > nowMonth)
          } : null,
          nameNormalized,
          addressNormalized,
          combined,
          originalIndex: index,
          score: 0
        };
      });

      const totalBuildings = buildings.length;
      const totalVacancies = buildings.reduce((sum, b) => sum + b.vacancyCountSafe, 0);
      document.querySelector('.intro-kpis .kpi:nth-child(1)').innerHTML = `<span>建物数</span>${formatCount(totalBuildings)}件`;
      document.querySelector('.intro-kpis .kpi:nth-child(2)').innerHTML = `<span>空部屋</span>${formatCount(totalVacancies)}件`;

      applyFiltersAndSort(true);
      const initialRendered = Math.min(PAGE_SIZE, buildings.length);
      const initDone = performance.now();
      console.info(
        `[v2][perf] initial_render_done source=${loadResult.sourceLabel} initial_count=${initialRendered} total_count=${buildings.length} total_elapsed_ms=${(initDone - loadResult.fetchStart).toFixed(2)}`
      );
    } catch (error) {
      showError('データの読み込みに失敗しました。時間をおいて再読み込みしてください。');
    }
  }

  loadMore.addEventListener('click', () => {
    displayLimit += PAGE_SIZE;
    render();
  });
  input.addEventListener('input', handleInput);
  input.addEventListener('search', handleInput);
  input.addEventListener('change', update);
  sortSelect.addEventListener('change', update);

  init();
})();
</script>
{% endblock %}
